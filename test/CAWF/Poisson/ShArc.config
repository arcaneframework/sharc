<?xml version="1.0" ?>
 <arcane-config code-name="ShArc">
  <time-loops>
    <time-loop name="PoissonLoop">
      <title>Fem</title>
      <description>Default timeloop for code Poisson</description>

      <modules>
        <module name="FemPoisson" need="required" />
        <module name="ArcanePostProcessing" need="required" />
      </modules>

      <entry-points where="init">
        <entry-point name="FemPoisson.StartInit" />
      </entry-points>
      <entry-points where="compute-loop">
        <entry-point name="FemPoisson.Compute" />
      </entry-points>
    </time-loop>
  </time-loops>
</arcane-config>
